# ─────────────────────────────────────────────────────────────
# AniStream environment variables
# Copy to `.env` for local dev. NEVER commit your real `.env`.
# ─────────────────────────────────────────────────────────────

# ── Frontend (Vite) ──
# Origin of the backend API server. Inlined into the build at build time,
# so on Vercel set this to your public backend URL (e.g. the ngrok URL).
# No trailing slash.
VITE_API_BASE=http://localhost:8080

# ── Backend (Termux on your phone) ──
# Port the API server (node server.js) listens on. This is the port ngrok
# tunnels. The KissKH relay (proxy.py) uses a SEPARATE port (PROXY_PORT) —
# do NOT point both at 8080 or one process will fail to bind.
PORT=8080

# Allowed CORS origin for the frontend. Use '*' for any origin, or set your
# Vercel URL (e.g. https://anistream.vercel.app) to lock it down.
CORS_ORIGIN=*

# ── Optional KissKH relay (proxy.py) ──
# Only needed if KissKH blocks the phone's IP. The phone is on a RESIDENTIAL
# IP, so by default you can leave KISSKH_BASE empty and hit kisskh.co directly
# — the relay was only required on the old datacenter (Railway) deployment.
# If you DO run proxy.py, give it its own port and point KISSKH_BASE at it.
PROXY_PORT=9090
KISSKH_BASE=
ENCDEC_BASE=
